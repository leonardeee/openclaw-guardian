#!/bin/bash
# Piper 启动脚本

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
NODE_PATH="/opt/homebrew/opt/node@22/bin/node"

if [ ! -x "$NODE_PATH" ]; then
  NODE_PATH=$(which node 2>/dev/null)
fi

if [ -z "$NODE_PATH" ]; then
  echo "错误: 找不到 Node.js"
  exit 1
fi

# 使用脚本所在目录
exec "$NODE_PATH" "$SCRIPT_DIR/piper.js" "$@"